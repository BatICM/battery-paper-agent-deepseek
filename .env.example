# DeepSeek API summarization
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=6000

# Optional but recommended for OpenAlex polite pool
CONTACT_EMAIL=your_email@example.com

# SMTP email push
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_or_smtp_authorization_code
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=receiver1@example.com,receiver2@example.com

# Optional Semantic Scholar API key
S2_API_KEY=
